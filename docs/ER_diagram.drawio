<mxfile host="app.diagrams.net" modified="2026-04-22T00:00:00.000Z" agent="Claude" version="22.0.0" type="device">
  <diagram name="HarmonyVault ER" id="hv-er-diagram">
    <mxGraphModel dx="1500" dy="950" grid="1" gridSize="20" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ============================================================ -->
        <!-- Title and legend                                              -->
        <!-- ============================================================ -->
        <mxCell id="title" value="&lt;b&gt;HarmonyVault &amp;mdash; Entity-Relationship Diagram&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=16" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="600" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="legend" value="&lt;span style='font-size:10px'&gt;Strong entity = single rectangle (blue) &amp;nbsp;&amp;bull;&amp;nbsp; Weak entity = double rectangle (green) &amp;nbsp;&amp;bull;&amp;nbsp; Identifying relationship = double diamond &amp;nbsp;&amp;bull;&amp;nbsp; Total participation = thick line &amp;nbsp;&amp;bull;&amp;nbsp; &lt;u&gt;underline&lt;/u&gt; = key, dashed underline = partial key&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="20" y="50" width="1200" height="20" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- STRONG ENTITIES (blue, single line, attributes inside)        -->
        <!-- ============================================================ -->
        <mxCell id="ent_user" value="&lt;b&gt;User&lt;/b&gt;&lt;br/&gt;&lt;u&gt;userID&lt;/u&gt;&lt;br/&gt;username&lt;br/&gt;email&lt;br/&gt;dateCreated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="200" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="ent_clip" value="&lt;b&gt;Clip&lt;/b&gt;&lt;br/&gt;&lt;u&gt;clipID&lt;/u&gt;&lt;br/&gt;title&lt;br/&gt;duration&lt;br/&gt;filepath&lt;br/&gt;dateCreated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="620" y="380" width="200" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="ent_project" value="&lt;b&gt;Project&lt;/b&gt;&lt;br/&gt;&lt;u&gt;projectID&lt;/u&gt;&lt;br/&gt;name&lt;br/&gt;description&lt;br/&gt;dateCreated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1180" y="380" width="200" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="ent_tag" value="&lt;b&gt;Tag&lt;/b&gt;&lt;br/&gt;&lt;u&gt;tagID&lt;/u&gt;&lt;br/&gt;tagName" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="100" y="800" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- WEAK ENTITIES (green, double-line rectangle)                  -->
        <!-- ============================================================ -->
        <mxCell id="ent_ma" value="&lt;b&gt;MusicalAttributes&lt;/b&gt;&lt;br/&gt;musicalKey&lt;br/&gt;mode&lt;br/&gt;tempo&lt;br/&gt;timeSignature" style="shape=rect;double=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="620" y="700" width="220" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="ent_cv" value="&lt;b&gt;ClipVersion&lt;/b&gt;&lt;br/&gt;&lt;span style='border-bottom:1px dashed #000'&gt;versionNumber&lt;/span&gt;&lt;br/&gt;notes&lt;br/&gt;filepath&lt;br/&gt;dateCreated" style="shape=rect;double=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1140" y="700" width="220" height="130" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- DIAMONDS - strong relationships (yellow, single line)         -->
        <!-- ============================================================ -->
        <mxCell id="rel_owns" value="Owns" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="395" y="405" width="130" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="rel_contains" value="Contains" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="915" y="405" width="140" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="rel_defines" value="Defines" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="620" width="140" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="rel_taggedwith" value="TaggedWith" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="380" y="720" width="160" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="rel_collab" value="Collaborates" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="470" y="180" width="170" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="rel_creates" value="Creates" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="850" y="195" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- DIAMONDS - identifying relationships (yellow, double line)    -->
        <!-- ============================================================ -->
        <mxCell id="rel_has" value="Has" style="rhombus;double=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="660" y="580" width="140" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="rel_hasversion" value="HasVersion" style="rhombus;double=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1090" y="580" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- ATTRIBUTE ELLIPSES on Collaborates (relationship attributes)  -->
        <!-- ============================================================ -->
        <mxCell id="attr_role" value="role" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="430" y="90" width="70" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="attr_addedat" value="addedAt" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="560" y="90" width="80" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="e_attr_role" style="endArrow=none;html=1;rounded=0;strokeColor=#666666;strokeWidth=1" edge="1" parent="1" source="attr_role" target="rel_collab">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_attr_addedat" style="endArrow=none;html=1;rounded=0;strokeColor=#666666;strokeWidth=1" edge="1" parent="1" source="attr_addedat" target="rel_collab">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- RELATIONSHIP EDGES                                            -->
        <!-- thin = partial participation, thick = total participation     -->
        <!-- each edge carries a cardinality label (1, N, or M)            -->
        <!-- ============================================================ -->

        <!-- Owns: User (1) <-> Clip (N), Clip total -->
        <mxCell id="e_user_owns" value="1" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="ent_user" target="rel_owns">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_owns_clip" value="N" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=2.5;fontSize=12;fontStyle=1" edge="1" parent="1" source="rel_owns" target="ent_clip">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Contains: Clip (M) <-> Project (N), both partial -->
        <mxCell id="e_clip_contains" value="M" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="ent_clip" target="rel_contains">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_contains_project" value="N" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="rel_contains" target="ent_project">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Has (identifying): Clip (1) <-> MusicalAttributes (1), MA total -->
        <mxCell id="e_clip_has" value="1" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="ent_clip" target="rel_has">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_has_ma" value="1" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=2.5;fontSize=12;fontStyle=1" edge="1" parent="1" source="rel_has" target="ent_ma">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- HasVersion (identifying): Clip (1) <-> ClipVersion (N), ClipVersion total -->
        <mxCell id="e_clip_hasversion" value="1" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="ent_clip" target="rel_hasversion">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_hasversion_cv" value="N" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=2.5;fontSize=12;fontStyle=1" edge="1" parent="1" source="rel_hasversion" target="ent_cv">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Defines: User (1) <-> Tag (N), Tag total -->
        <mxCell id="e_user_defines" value="1" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="ent_user" target="rel_defines">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_defines_tag" value="N" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=2.5;fontSize=12;fontStyle=1" edge="1" parent="1" source="rel_defines" target="ent_tag">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- TaggedWith: Clip (M) <-> Tag (N), both partial -->
        <mxCell id="e_clip_tagged" value="M" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="ent_clip" target="rel_taggedwith">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_tagged_tag" value="N" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="rel_taggedwith" target="ent_tag">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Collaborates: User (M) <-> Project (N), both partial -->
        <mxCell id="e_user_collab" value="M" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="ent_user" target="rel_collab">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_collab_project" value="N" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="rel_collab" target="ent_project">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Creates: User (1) <-> Project (N), Project total -->
        <mxCell id="e_user_creates" value="1" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=1;fontSize=12;fontStyle=1" edge="1" parent="1" source="ent_user" target="rel_creates">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_creates_project" value="N" style="endArrow=none;html=1;rounded=0;strokeColor=#333333;strokeWidth=2.5;fontSize=12;fontStyle=1" edge="1" parent="1" source="rel_creates" target="ent_project">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
